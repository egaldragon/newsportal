<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>Analytics</title>
	<link href='https://unpkg.com/boxicons@2.0.9/css/boxicons.min.css' rel='stylesheet'>
	<link rel="stylesheet" type="text/css" href="styles/adminPanel.css">
	<style>
		:root {
			--card-border: #e8eaef;
		}

		.analytics-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
			gap: 20px;
			margin-top: 20px;
		}

		.card {
			background: #fff;
			border-radius: 14px;
			padding: 18px;
			border: 1px solid var(--card-border);
			box-shadow: 0 6px 18px rgba(15, 23, 42, 0.06);
		}

		.card h3 {
			margin-bottom: 12px;
			font-size: 18px;
		}

		.metric-row {
			display: flex;
			justify-content: space-between;
			align-items: center;
			padding: 8px 0;
			border-bottom: 1px dashed #eee;
		}

		.metric-row:last-child {
			border-bottom: 0;
		}

		.metric-label {
			color: #666;
			font-size: 14px;
		}

		.metric-value {
			font-weight: 700;
		}

		.chart-card {
			margin-top: 20px;
		}

		/* Prevent top margin from stacking when chart cards are inside grid containers. */
		.analytics-grid .chart-card {
			margin-top: 0;
		}

		.box-info li {
			border: 1px solid var(--card-border);
			box-shadow: 0 6px 14px rgba(15, 23, 42, 0.04);
		}

		.table-card table {
			width: 100%;
			border-collapse: collapse;
		}

		.table-card th,
		.table-card td {
			text-align: left;
			padding: 10px;
			border-bottom: 1px solid #f1f1f1;
			font-size: 14px;
		}

		.badge {
			display: inline-block;
			padding: 4px 10px;
			border-radius: 999px;
			font-size: 12px;
			font-weight: 600;
		}

		.badge-published {
			background: #e8f4ff;
			color: #1565c0;
		}

		.badge-upcoming {
			background: #fff4e5;
			color: #d17b00;
		}

		@media (max-width: 768px) {
			.chart-card canvas {
				height: 260px !important;
			}
		}
	</style>
</head>

<body>
	<section id="sidebar">
		<a href="#" class="brand">
			<i class='bx bxs-smile'></i>
			<span class="text">AdminPanel</span>
		</a>
		<ul class="side-menu top">
			<li>
				<a href="/adminPage">
					<i class='bx bxs-dashboard'></i>
					<span class="text">Dashboard</span>
				</a>
			</li>
			<li>
				<a href="/addNews">
					<i class='bx bxs-shopping-bag-alt'></i>
					<span class="text">Add News</span>
				</a>
			</li>
			<li class="active">
				<a href="/Analytics">
					<i class='bx bxs-doughnut-chart'></i>
					<span class="text">Analytics</span>
				</a>
			</li>
			<li>
				<a href="/allNews">
					<i class='bx bxs-message-dots'></i>
					<span class="text">All News</span>
				</a>
			</li>
			<li>
				<a href="/upcoming">
					<i class='bx bxs-group'></i>
					<span class="text">Upcoming Posts</span>
				</a>
			</li>
		</ul>
		<ul class="side-menu">
			<li>
				<a href="/setting">
					<i class='bx bxs-cog'></i>
					<span class="text">Settings</span>
				</a>
			</li>
			<li>
				<a href="/logout" class="logout">
					<i class='bx bxs-log-out-circle'></i>
					<span class="text">Logout</span>
				</a>
			</li>
		</ul>
	</section>

	<section id="content">
		<nav>
			<i class='bx bx-menu'></i>
			<a href="#" class="nav-link">Categories</a>
			<form action="#">
				<div class="form-input">
					<input type="search" placeholder="Search...">
					<button type="submit" class="search-btn"><i class='bx bx-search'></i></button>
				</div>
			</form>
			<input type="checkbox" id="switch-mode" hidden>
			<label for="switch-mode" class="switch-mode"></label>
			<a href="#" class="profile">
				<% if (locals.admin_post) { %>
					<img src="/uploads/<%= admin_post.admin_img %>">
				<% } else { %>
					<img src="images/people.png">
				<% } %>
			</a>
		</nav>

		<main>
			<div class="head-title">
				<div class="left">
					<h1>Analytics</h1>
					<ul class="breadcrumb">
						<li><a href="/adminPage">Dashboard</a></li>
						<li><i class='bx bx-chevron-right'></i></li>
						<li><a class="active" href="#">Analytics</a></li>
					</ul>
				</div>
			</div>

			<ul class="box-info">
				<li>
					<i class='bx bxs-group'></i>
					<span class="text">
						<h3><%= locals.totalVisits || 0 %></h3>
						<p>Total Visitors</p>
					</span>
				</li>
				<li>
					<i class='bx bxs-news'></i>
					<span class="text">
						<h3><%= locals.Total_news || 0 %></h3>
						<p>Total Published News</p>
					</span>
				</li>
				<li>
					<i class='bx bxs-time-five'></i>
					<span class="text">
						<h3><%= locals.upcoming_news || 0 %></h3>
						<p>Upcoming News</p>
					</span>
				</li>
			</ul>

			<div class="analytics-grid">
				<div class="card">
					<h3>Performance Snapshot</h3>
					<div class="metric-row">
						<span class="metric-label">Visitor-to-Published Conversion</span>
						<span class="metric-value" id="conversionRate">0%</span>
					</div>
					<div class="metric-row">
						<span class="metric-label">Upcoming Ratio</span>
						<span class="metric-value" id="upcomingRatio">0%</span>
					</div>
					<div class="metric-row">
						<span class="metric-label">Top Category</span>
						<span class="metric-value" id="topCategory">-</span>
					</div>
				</div>

				<div class="card table-card">
					<h3>Top Categories</h3>
					<table>
						<thead>
							<tr>
								<th>Category</th>
								<th>Total</th>
							</tr>
						</thead>
						<tbody id="topCategoryBody"></tbody>
					</table>
				</div>
			</div>

			<div class="card chart-card">
				<h3>Traffic vs Content</h3>
				<canvas id="trafficContentChart" height="95"></canvas>
			</div>

			<div class="analytics-grid">
				<div class="card chart-card">
					<h3>Content Composition</h3>
					<canvas id="contentCompositionChart" height="180"></canvas>
				</div>

				<div class="card table-card">
					<h3>Latest Published Posts</h3>
					<table>
						<thead>
							<tr>
								<th>Title</th>
								<th>Date</th>
								<th>Status</th>
							</tr>
						</thead>
						<tbody id="latestPublishedBody"></tbody>
					</table>
				</div>
			</div>

			<div class="card table-card" style="margin-top: 20px;">
				<h3>Latest Upcoming Posts</h3>
				<table>
					<thead>
						<tr>
							<th>Title</th>
							<th>Scheduled</th>
							<th>Status</th>
						</tr>
					</thead>
					<tbody id="latestUpcomingBody"></tbody>
				</table>
			</div>
		</main>
	</section>

	<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
	<script src="assets/js/admin.js"></script>
	<script>
		const totalVisits = Number("<%= locals.totalVisits || 0 %>");
		const totalNews = Number("<%= locals.Total_news || 0 %>");
		const totalUpcoming = Number("<%= locals.upcoming_news || 0 %>");
		const publishedPosts = <%- JSON.stringify(locals.published_posts || []) %>;
		const upcomingPosts = <%- JSON.stringify(locals.upcoming_posts || []) %>;

		const categoryCounts = {};
		for (const post of publishedPosts) {
			const key = (post.catgeory || "Uncategorized").trim() || "Uncategorized";
			categoryCounts[key] = (categoryCounts[key] || 0) + 1;
		}

		const sortedCategories = Object.entries(categoryCounts)
			.sort((a, b) => b[1] - a[1]);

		const topCategory = sortedCategories.length ? sortedCategories[0][0] : "-";
		const conversion = totalVisits > 0 ? ((totalNews / totalVisits) * 100) : 0;
		const upcomingRatio = (totalNews + totalUpcoming) > 0
			? ((totalUpcoming / (totalNews + totalUpcoming)) * 100)
			: 0;

		document.getElementById("conversionRate").textContent = `${conversion.toFixed(2)}%`;
		document.getElementById("upcomingRatio").textContent = `${upcomingRatio.toFixed(2)}%`;
		document.getElementById("topCategory").textContent = topCategory;

		const topCategoryBody = document.getElementById("topCategoryBody");
		if (!sortedCategories.length) {
			topCategoryBody.innerHTML = "<tr><td colspan='2'>No category data available yet.</td></tr>";
		} else {
			topCategoryBody.innerHTML = sortedCategories.slice(0, 5)
				.map(([name, count]) => `<tr><td>${name}</td><td>${count}</td></tr>`)
				.join("");
		}

		const latestPublishedBody = document.getElementById("latestPublishedBody");
		const latestPublished = [...publishedPosts].slice(-5).reverse();
		latestPublishedBody.innerHTML = latestPublished.length
			? latestPublished.map((post) => `
				<tr>
					<td>${post.title || "No title"}</td>
					<td>${post.date || "-"}</td>
					<td><span class="badge badge-published">Published</span></td>
				</tr>
			`).join("")
			: "<tr><td colspan='3'>No published posts yet.</td></tr>";

		const latestUpcomingBody = document.getElementById("latestUpcomingBody");
		const latestUpcoming = [...upcomingPosts].slice(-5).reverse();
		latestUpcomingBody.innerHTML = latestUpcoming.length
			? latestUpcoming.map((post) => `
				<tr>
					<td>${post.title || "No title"}</td>
					<td>${post.postDate || post.date || "-"} ${post.postTime || ""}</td>
					<td><span class="badge badge-upcoming">Upcoming</span></td>
				</tr>
			`).join("")
			: "<tr><td colspan='3'>No upcoming posts yet.</td></tr>";

		new Chart(document.getElementById("trafficContentChart"), {
			type: "bar",
			data: {
				labels: ["Visitors", "Published", "Upcoming"],
				datasets: [{
					label: "Total",
					data: [totalVisits, totalNews, totalUpcoming],
					backgroundColor: ["#3C91E6", "#34A853", "#F9AB00"],
					borderRadius: 8,
				}]
			},
			options: {
				responsive: true,
				plugins: {
					legend: { display: false }
				}
			}
		});

		new Chart(document.getElementById("contentCompositionChart"), {
			type: "doughnut",
			data: {
				labels: sortedCategories.slice(0, 6).map((x) => x[0]),
				datasets: [{
					data: sortedCategories.slice(0, 6).map((x) => x[1]),
					backgroundColor: ["#3366CC", "#DC3912", "#FF9900", "#109618", "#990099", "#0099C6"],
				}]
			},
			options: {
				responsive: true,
				plugins: {
					legend: {
						position: "bottom"
					}
				}
			}
		});
	</script>
</body>

</html>
